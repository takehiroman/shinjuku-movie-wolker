{
  "name": "shinjuku-movie-wolker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:build:core": "node ./sample-data/build-seed.mjs ./sample-data/sources/core-2026-04-18 ./sample-data/shinjuku-core-2026-04-18.json",
    "cf:check": "wrangler check",
    "cf:types": "wrangler types ./src/worker-configuration.d.ts",
    "d1:migrate:local": "wrangler d1 migrations apply shinjuku-movie-wolker --local",
    "d1:migrate:remote": "wrangler d1 migrations apply shinjuku-movie-wolker --remote"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2",
    "wrangler": "^4.12.0"
  }
}
